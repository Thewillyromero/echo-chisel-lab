    },
    "credential_id": "{{VAPI_CREDENTIAL_ID}}",
    "phone_ids": [
      "{{VAPI_PHONE_1}}"
    ]
  },
  "integrations": {
    "crm_type": "{{CRM_TYPE}}",
    "crm_webhook": "{{CRM_WEBHOOK}}",
    "calendar_type": "{{CALENDAR_TYPE}}",
    "calendar_id": "{{CALENDAR_ID}}",
    "notification_channel": "{{NOTIFICATION_CHANNEL}}"
  },
  "voice": {
    "nombre_asistente": "{{NOMBRE_ASISTENTE}}",
    "voice_id": "{{VOICE_ID}}",
    "saludo": "{{SALUDO}}"
  }
}
