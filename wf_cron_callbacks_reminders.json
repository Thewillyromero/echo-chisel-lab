      "parameters": {
        "jsCode": "// Build 1h reminder SMS for each cita\nconst input = $input.first().json;\nconst records = input.records || [];\n\nif (!records.length) {\n  return [{ json: { hasReminders: false } }];\n}\n\nconst contactInfo = 'Mas info: admin@psycoboost.com | WA: wa.me/34982685874';\n\nconst items = records.map(r => {\n  const f = r.fields || {};\n  const nombre = f.nombre || '';\n  const phone = f.telefono || '';\n  const phone9 = phone.replace('+34','').replace('+','').trim().slice(-9);\n  const isMobile = phone9.startsWith('6') || phone9.startsWith('7');\n\n  let horaStr = '';\n  if (f.fecha_cita) {\n    try {\n      const d = new Date(f.fecha_cita);\n      horaStr = d.toLocaleTimeString('es-ES', { timeZone: 'Europe/Madrid', hour: '2-digit', minute: '2-digit' });\n    } catch(e) {}\n  }\n\n  const smsText = (nombre ? 'Hola ' + nombre + '! ' : 'Hola! ') + 'En 1 hora tienes tu sesion de discovery call' + (horaStr ? ' (a las ' + horaStr + ')' : '') + '. Asegurate de estar disponible. Te esperamos! ' + contactInfo;\n\n  return {\n    json: {\n      recordId: r.id,\n      phone,\n      isMobile,\n      smsText,\n      hasReminders: true\n    }\n  };\n});\n\nreturn items;"
      },
