    {
      "parameters": {
        "jsCode": "// Build VAPI call payloads for each due callback\nconst input = $input.first().json;\nconst records = input.records || [];\n\nif (!records.length) {\n  return [{ json: { hasCallbacks: false, payloads: [] } }];\n}\n\nconst payloads = records.map(r => {\n  const f = r.fields || {};\n  return {\n    recordId: r.id,\n    phone: f.telefono || '',\n    nombre: f.nombre || 'Desconocido',\n    leadId: f.lead_id || '',\n    vapiPayload: {\n      assistantId: '03a2bdfd-c35d-4116-ab53-a91eb24774f8',\n      phoneNumberId: '2339e804-8989-4047-a5c0-7d2e614d6076',\n      customer: {\n        number: f.telefono || ''\n      },\n      assistantOverrides: {\n        variableValues: {\n          first_name: f.nombre || '',\n          lead_id: f.lead_id || '',\n          is_callback: 'true',\n          previous_resultado: f.resultado || '',\n          objeciones: f.objeciones || ''\n        }\n      }\n    }\n  };\n});\n\nreturn payloads.map(p => ({ json: p }));"
      },
