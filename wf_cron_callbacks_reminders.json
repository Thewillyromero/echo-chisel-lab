      "id": "cr-cron-1",
      "name": "Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [200, 400]
    },
    {
      "parameters": {
        "jsCode": "// Build Airtable filter for callbacks due in the next 15 minutes\nconst now = new Date();\nconst in15 = new Date(now.getTime() + 15 * 60 * 1000);\n\n// Format for Airtable DATETIME_PARSE comparison\nconst nowISO = now.toISOString();\nconst in15ISO = in15.toISOString();\n\n// Also compute tomorrow date range for 24h reminders (Madrid timezone)\n// We use a 15-min window approach: citas happening tomorrow\nconst madridOffset = 1; // CET = UTC+1 (CEST = UTC+2, adjust seasonally)\nconst madridNow = new Date(now.getTime() + madridOffset * 3600000);\nconst tomorrow = new Date(madridNow);\ntomorrow.setDate(tomorrow.getDate() + 1);\nconst tomorrowStr = tomorrow.toISOString().split('T')[0];\n\n// 1h reminders: citas in the next 60-75 minutes\nconst in60 = new Date(now.getTime() + 60 * 60 * 1000);\nconst in75 = new Date(now.getTime() + 75 * 60 * 1000);\nconst in60ISO = in60.toISOString();\nconst in75ISO = in75.toISOString();\n\nreturn [{ json: {\n  nowISO,\n  in15ISO,\n  in60ISO,\n  in75ISO,\n  tomorrowStr\n} }];"
      },
      "id": "cr-compute-times-1",
      "name": "Compute Time Windows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "url": "=https://api.airtable.com/v0/appMKzx72jwPbVeAg/tblxspXF93Nv5ojGc?filterByFormula=AND(IS_AFTER(callback_datetime, '{{ $json.nowISO }}'), IS_BEFORE(callback_datetime, '{{ $json.in15ISO }}'), callback_ejecutado=FALSE(), do_not_contact=FALSE())&maxRecords=50",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer AIRTABLE_TOKEN_PLACEHOLDER"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
